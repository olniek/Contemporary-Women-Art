# Required for POST /api/ask (Vercel serverless or `vercel dev`)
OPENAI_API_KEY=

# Local Ask: copy this file to `.env.local` (gitignored), set OPENAI_API_KEY, then run `npx vercel dev`.

# Optional fallback name (only used if OPENAI_API_KEY is unset — prefer OPENAI_API_KEY in Vercel)
# OPENAI_KEY=

# Optional: restrict CORS to your static site origin (e.g. https://your-site.vercel.app, or http://127.0.0.1:8000 when HTML is static and API is on Vercel). Default is *.
# WIA_CORS_ORIGIN=
